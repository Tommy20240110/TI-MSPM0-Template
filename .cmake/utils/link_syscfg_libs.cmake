# link_syscfg_libs.cmake
# Read library entries generated by SysConfig.
# Supports two formats:
#   .lds.genlibs:  INPUT("path/to/lib.a")   (GNU LD, GCC/Clang)
#   .cmd.genlibs:  -l"path/to/lib.a"        (TI linker, TIClang)

function(link_syscfg_libs TARGET TI_SDK_ROOT GENLIBS_FILE)
    if(NOT EXISTS "${GENLIBS_FILE}")
        return()
    endif()

    # Detect format: .lds uses INPUT(...), .cmd uses -l"..."
    file(STRINGS "${GENLIBS_FILE}" RAW_LINES)
    set(HAS_INPUT FALSE)
    set(HAS_MINUS_L FALSE)
    foreach(LINE ${RAW_LINES})
        string(STRIP "${LINE}" STRIPPED)
        if(STRIPPED MATCHES "^INPUT\\(")
            set(HAS_INPUT TRUE)
        endif()
        if(STRIPPED MATCHES "^-l\"")
            set(HAS_MINUS_L TRUE)
        endif()
    endforeach()

    set(INPUT_LINES "")
    if(HAS_MINUS_L)
        # .cmd.genlibs format: -l"path/to/lib.a"
        foreach(LINE ${RAW_LINES})
            string(STRIP "${LINE}" STRIPPED)
            if(STRIPPED MATCHES "^-l\"")
                string(REGEX REPLACE "^-l\"(.*)\"$" "\\1" LIB_PATH "${STRIPPED}")
                list(APPEND INPUT_LINES "${LIB_PATH}")
            endif()
        endforeach()
    elseif(HAS_INPUT)
        # .lds.genlibs format: INPUT("path/to/lib.a")
        foreach(LINE ${RAW_LINES})
            string(STRIP "${LINE}" STRIPPED)
            if(STRIPPED MATCHES "^INPUT\\(")
                string(REPLACE "INPUT(\"" "" LIB_PATH "${STRIPPED}")
                string(REPLACE "\")" "" LIB_PATH "${LIB_PATH}")
                list(APPEND INPUT_LINES "${LIB_PATH}")
            endif()
        endforeach()
    endif()

    list(LENGTH INPUT_LINES LINE_COUNT)
    message(STATUS "link_syscfg_libs: ${LINE_COUNT} libraries from SysConfig")

    set(MISSING "")

    foreach(LIB_PATH ${INPUT_LINES})
        set(FULL_PATH "${TI_SDK_ROOT}/source/${LIB_PATH}")
        if(EXISTS "${FULL_PATH}")
            target_link_libraries(${TARGET} PRIVATE "${FULL_PATH}")
        else()
            list(APPEND MISSING "${LIB_PATH}")
        endif()
    endforeach()

    if(MISSING)
        message("")
        message("    The following libraries do not exist in the genlibs file generated by SysConfig:")
        foreach(LIB ${MISSING})
            message("     ${LIB}")
        endforeach()
        message("")
        message("Please disable the corresponding genLib* function in .syscfg, or install the corresponding SDK component")
        message(FATAL_ERROR "Fix the issues above, then reconfigure")
    endif()
endfunction()
