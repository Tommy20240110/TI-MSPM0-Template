{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "TI Sysconfig build",
            "type": "shell",
            "command": "${workspaceFolder}/.ti/syscfg.bat",
            "args": [
                "${workspaceFolder}",
                "${workspaceFolderBasename}",
                "${config:ti.sysconfig.root}",
                "${config:ti.sdk.root}"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset", "user-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake build",
            "type": "cmake",
            "command": "build",
            "targets": [
                "${workspaceFolderBasename}"
            ],
            "dependsOn": [
                "TI Sysconfig build",
                "CMake configure"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
        },
        {
            "label": "CMake clean",
            "type": "cmake",
            "command": "clean",
        },
        {
            "label": "CMake clean rebuild",
            "type": "cmake",
            "command": "cleanRebuild",
        }
    ]
}